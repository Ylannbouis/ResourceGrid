# Postgres connection (matches docker-compose.yml — host port 5433 to avoid clashes)
DATABASE_URL="postgresql://resourcegrid:resourcegrid@localhost:5433/resourcegrid?schema=public"

# API server port
PORT=3001

# Comma-separated list of allowed web origins for CORS + Socket.IO
WEB_ORIGIN="http://localhost:3000"

# How long a pin stays live before the sweeper expires it (hours)
PIN_TTL_HOURS=24

# AI Voice Triage — speech-to-text (Deepgram) + extraction (Claude).
# Both must be set for the mic button to appear; otherwise the feature is disabled.
DEEPGRAM_API_KEY=
ANTHROPIC_API_KEY=
